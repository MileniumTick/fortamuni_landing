---
interface Props {
  title: string;
  description: string;
  keywords?: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title,
  description,
  keywords = "gestión vial municipal, planes viales quinquenales, inventario vial cantonal, NICSP, municipalidades Costa Rica, UTGV, Fortamuni, Saskya Montealegre",
  canonical = "https://fortamuni.cr/",
  ogImage = "https://fortamuni.cr/og-image.jpg"
} = Astro.props;

const isHome = Astro.url.pathname === "/";
const navBase = isHome ? "" : "/";
const homeHref = isHome ? "#hero" : "/";
const contactHref = `${navBase}#contacto`;
---

<!doctype html>
<html lang="es-CR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <meta name="author" content="Fortamuni" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#1a365d" />
    <meta name="color-scheme" content="light" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_CR" />
    <meta property="og:site_name" content="Fortamuni" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <slot name="head" />
  </head>
  <body class="bg-background text-foreground antialiased">
    <a
      href="#contenido-principal"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-md focus:bg-accent focus:px-4 focus:py-2 focus:text-accent-foreground"
    >
      Ir al contenido principal
    </a>

    <header
      id="header"
      class="fixed inset-x-0 top-0 z-50 border-b border-white/10 bg-primary/90 backdrop-blur-sm transition-all duration-300"
    >
      <nav
        aria-label="Navegación principal"
        class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8"
      >
        <a href={homeHref} class="flex items-center gap-3" aria-label="Ir al inicio de Fortamuni">
          <span
            class="flex h-11 w-11 items-center justify-center rounded-xl border border-accent/40 bg-accent/10 text-lg font-extrabold text-accent"
            aria-hidden="true"
          >
            F
          </span>
          <span class="flex flex-col">
            <span class="text-lg font-extrabold tracking-[0.24em] text-primary-foreground">FORTAMUNI</span>
            <span class="text-xs font-medium text-primary-foreground/70">Gestión vial municipal</span>
          </span>
        </a>

        <button
          type="button"
          class="inline-flex items-center justify-center rounded-lg border border-white/15 p-3 text-primary-foreground lg:hidden"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Abrir menú de navegación"
          data-menu-toggle
        >
          <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-6 w-6 fill-none stroke-current stroke-2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 7h16M4 12h16M4 17h16" />
          </svg>
        </button>

        <div class="hidden items-center gap-8 lg:flex">
          <a class="text-sm font-medium text-primary-foreground/80 transition hover:text-accent" href={`${navBase}#nosotros`} data-nav-link>Nosotros</a>
          <a class="text-sm font-medium text-primary-foreground/80 transition hover:text-accent" href={`${navBase}#servicios`} data-nav-link>Servicios</a>
          <a class="text-sm font-medium text-primary-foreground/80 transition hover:text-accent" href={`${navBase}#casos-de-exito`} data-nav-link>Casos de éxito</a>
          <a class="text-sm font-medium text-primary-foreground/80 transition hover:text-accent" href={contactHref} data-nav-link>Contacto</a>
          <a
            href={contactHref}
            class="inline-flex items-center justify-center rounded-full bg-accent px-5 py-3 text-sm font-bold text-accent-foreground transition hover:bg-gold-light"
          >
            Agendar diagnóstico
          </a>
        </div>
      </nav>

      <div id="mobile-menu" class="mobile-menu border-t border-white/10 bg-primary lg:hidden">
        <div class="space-y-1 px-4 py-4 sm:px-6">
          <a class="block rounded-lg px-4 py-3 text-sm font-medium text-primary-foreground/85 hover:bg-white/5" href={`${navBase}#nosotros`} data-nav-link>Nosotros</a>
          <a class="block rounded-lg px-4 py-3 text-sm font-medium text-primary-foreground/85 hover:bg-white/5" href={`${navBase}#servicios`} data-nav-link>Servicios</a>
          <a class="block rounded-lg px-4 py-3 text-sm font-medium text-primary-foreground/85 hover:bg-white/5" href={`${navBase}#casos-de-exito`} data-nav-link>Casos de éxito</a>
          <a class="block rounded-lg px-4 py-3 text-sm font-medium text-primary-foreground/85 hover:bg-white/5" href={contactHref} data-nav-link>Contacto</a>
          <a
            href={contactHref}
            class="mt-3 inline-flex w-full items-center justify-center rounded-full bg-accent px-5 py-3 text-sm font-bold text-accent-foreground"
          >
            Agendar diagnóstico
          </a>
        </div>
      </div>
    </header>

    <main id="contenido-principal">
      <slot />
    </main>

    <footer class="border-t border-border bg-surface px-4 py-12 sm:px-6 lg:px-8">
      <div class="mx-auto grid max-w-7xl gap-8 text-sm text-muted-foreground md:grid-cols-1 lg:grid-cols-3">
        <div>
          <p class="font-bold text-primary text-lg">Fortamuni</p>
          <p class="mt-4">Consultoría especializada en gestión vial municipal y planificación estratégica para gobiernos locales de Costa Rica.</p>
        </div>
        <div>
          <p class="font-bold text-primary">Contenidos Especializados</p>
          <ul class="mt-4 space-y-3">
            <li><a href="/planes-viales-quinquenales-municipales/" class="hover:text-accent transition">Planes Viales Quinquenales (PVQCD)</a></li>
            <li><a href="/inventario-red-vial-cantonal/" class="hover:text-accent transition">Inventario de la Red Vial Cantonal</a></li>
            <li><a href="/valoracion-activos-viales-nicsp/" class="hover:text-accent transition">Valoración NICSP de Activos Viales</a></li>
            <li><a href="/cumplimiento-ley-8114-ley-9329/" class="hover:text-accent transition">Cumplimiento Ley 8114 y 9329</a></li>
            <li><a href="/utgv-planificacion-y-priorizacion-vial/" class="hover:text-accent transition">UTGV: Planificación y Priorización</a></li>
            <li><a href="/guia/que-es-un-pvqcd/" class="hover:text-accent transition">¿Qué es un PVQCD?</a></li>
            <li><a href="/guia/como-priorizar-inversion-en-red-vial-cantonal/" class="hover:text-accent transition">Guía de priorización de inversión</a></li>
            <li><a href="/guia/errores-en-valoracion-de-activos-viales-nicsp/" class="hover:text-accent transition">Errores comunes en valoración NICSP</a></li>
          </ul>
        </div>
        <div class="lg:text-right">
          <p class="font-bold text-primary">Dirección Técnica</p>
          <div class="mt-4 space-y-2">
            <p>Ing. Ind. Saskya Carolina Montealegre Cascante</p>
            <p>Correo: info@fortamuni.com</p>
          </div>
        </div>
      </div>
    </footer>
    <script type="module" src="/src/main.ts"></script>
  </body>
</html>
