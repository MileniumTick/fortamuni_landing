---
interface Props {
  title: string;
  description: string;
  keywords?: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title,
  description,
  keywords = "gestión vial municipal, planes viales quinquenales, inventario vial cantonal, NICSP, municipalidades Costa Rica, UTGV, Fortamuni, Saskya Montealegre",
  canonical = "https://fortamuni.com/",
  ogImage = "https://fortamuni.com/og-image.jpg"
} = Astro.props;

const isHome = Astro.url.pathname === "/";
const navBase = isHome ? "" : "/";
const homeHref = isHome ? "#hero" : "/";
const contactHref = `${navBase}#contacto`;
---

<!doctype html>
<html lang="es-CR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <meta name="author" content="Fortamuni" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#15558c" />
    <meta name="color-scheme" content="light" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_CR" />
    <meta property="og:site_name" content="Fortamuni" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <slot name="head" />
  </head>
  <body class="bg-background text-foreground antialiased">
    <a
      href="#contenido-principal"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-md focus:bg-accent focus:px-4 focus:py-2 focus:text-accent-foreground"
    >
      Ir al contenido principal
    </a>

    <header
      id="header"
      class="fixed inset-x-0 top-0 z-50 border-b border-white/10 bg-primary/90 backdrop-blur-sm transition-all duration-300"
    >
      <nav
        aria-label="Navegación principal"
        class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8"
      >
        <a href={homeHref} class="flex items-center gap-3" aria-label="Ir al inicio de Fortamuni">
          <span class="flex h-12 w-12 items-center justify-center rounded-2xl bg-white/8 p-1.5 shadow-lg shadow-black/10" aria-hidden="true">
            <img src="/fortamuni-mark.svg" alt="" class="h-full w-full" loading="eager" decoding="async" />
          </span>
          <span class="flex flex-col">
            <span class="text-lg font-extrabold tracking-[0.24em] text-primary-foreground">FORTAMUNI</span>
            <span class="text-xs font-medium text-primary-foreground/72">Gestión vial municipal</span>
          </span>
        </a>

        <button
          type="button"
          class="inline-flex items-center justify-center rounded-lg border border-white/15 p-3 text-primary-foreground lg:hidden"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Abrir menú de navegación"
          data-menu-toggle
        >
          <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-6 w-6 fill-none stroke-current stroke-2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 7h16M4 12h16M4 17h16" />
          </svg>
        </button>

        <div class="hidden items-center gap-8 lg:flex">
          <a class="text-sm font-medium text-primary-foreground/80 transition hover:text-white" href={`${navBase}#nosotros`} data-nav-link>Nosotros</a>
          <a class="text-sm font-medium text-primary-foreground/80 transition hover:text-white" href={`${navBase}#servicios`} data-nav-link>Servicios</a>
          <a class="text-sm font-medium text-primary-foreground/80 transition hover:text-white" href={`${navBase}#casos-de-exito`} data-nav-link>Casos de éxito</a>
          <a class="text-sm font-medium text-primary-foreground/80 transition hover:text-white" href={contactHref} data-nav-link>Contacto</a>
          <a
            href={contactHref}
            class="inline-flex items-center justify-center rounded-full bg-accent px-5 py-3 text-sm font-bold text-accent-foreground transition hover:bg-[var(--color-accent-hover)]"
          >
            Agendar diagnóstico
          </a>
        </div>
      </nav>

      <div id="mobile-menu" class="mobile-menu border-t border-white/10 bg-primary-deep lg:hidden">
        <div class="space-y-1 px-4 py-4 sm:px-6">
          <a class="block rounded-lg px-4 py-3 text-sm font-medium text-primary-foreground/85 hover:bg-white/5" href={`${navBase}#nosotros`} data-nav-link>Nosotros</a>
          <a class="block rounded-lg px-4 py-3 text-sm font-medium text-primary-foreground/85 hover:bg-white/5" href={`${navBase}#servicios`} data-nav-link>Servicios</a>
          <a class="block rounded-lg px-4 py-3 text-sm font-medium text-primary-foreground/85 hover:bg-white/5" href={`${navBase}#casos-de-exito`} data-nav-link>Casos de éxito</a>
          <a class="block rounded-lg px-4 py-3 text-sm font-medium text-primary-foreground/85 hover:bg-white/5" href={contactHref} data-nav-link>Contacto</a>
          <a
            href={contactHref}
            class="mt-3 inline-flex w-full items-center justify-center rounded-full bg-accent px-5 py-3 text-sm font-bold text-accent-foreground transition hover:bg-[var(--color-accent-hover)]"
          >
            Agendar diagnóstico
          </a>
        </div>
      </div>
    </header>

    <main id="contenido-principal">
      <slot />
    </main>

    <footer class="border-t border-border bg-surface px-4 py-12 sm:px-6 lg:px-8">
      <div class="mx-auto grid max-w-7xl gap-8 text-sm text-muted-foreground md:grid-cols-1 lg:grid-cols-3">
        <div>
          <img
            src="/fortamuni-logo.svg"
            alt="Fortamuni"
            class="h-14 w-auto"
            loading="lazy"
            decoding="async"
          />
          <p class="mt-4">Consultoría especializada en gestión vial municipal y planificación estratégica para gobiernos locales de Costa Rica.</p>
        </div>
        <div>
          <p class="font-bold text-primary">Contenidos Especializados</p>
          <ul class="mt-4 space-y-3">
            <li><a href="/planes-viales-quinquenales-municipales/" class="hover:text-accent transition">Planes Viales Quinquenales (PVQCD)</a></li>
            <li><a href="/inventario-red-vial-cantonal/" class="hover:text-accent transition">Inventario de la Red Vial Cantonal</a></li>
            <li><a href="/valoracion-activos-viales-nicsp/" class="hover:text-accent transition">Valoración NICSP de Activos Viales</a></li>
            <li><a href="/cumplimiento-ley-8114-ley-9329/" class="hover:text-accent transition">Cumplimiento Ley 8114 y 9329</a></li>
            <li><a href="/utgv-planificacion-y-priorizacion-vial/" class="hover:text-accent transition">UTGV: Planificación y Priorización</a></li>
            <li><a href="/guia/que-es-un-pvqcd/" class="hover:text-accent transition">¿Qué es un PVQCD?</a></li>
            <li><a href="/guia/como-priorizar-inversion-en-red-vial-cantonal/" class="hover:text-accent transition">Guía de priorización de inversión</a></li>
            <li><a href="/guia/errores-en-valoracion-de-activos-viales-nicsp/" class="hover:text-accent transition">Errores comunes en valoración NICSP</a></li>
          </ul>
        </div>
        <div class="lg:text-right">
          <p class="font-bold text-primary">Dirección Técnica</p>
          <div class="mt-4 space-y-2">
            <p>Ing. Ind. Saskya Carolina Montealegre Cascante</p>
            <p>Correo: fortamunisaskya@gmail.com</p>
          </div>
        </div>
      </div>
    </footer>

    <a
      href="https://wa.me/50672034589?text=Hola%20Fortamuni%2C%20quiero%20informaci%C3%B3n%20sobre%20la%20asesor%C3%ADa%20para%20mi%20municipalidad."
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Escribir por WhatsApp"
      class="group fixed bottom-5 right-5 z-[60] inline-flex h-14 w-14 items-center justify-center rounded-full bg-[#25D366] text-white shadow-[0_12px_30px_rgba(37,211,102,0.45)] transition-transform duration-200 hover:scale-105 hover:bg-[#20ba59] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-[#0b2742] sm:bottom-6 sm:right-6"
    >
      <svg aria-hidden="true" viewBox="0 0 24 24" class="h-7 w-7 fill-current">
        <path d="M20.52 3.48A11.86 11.86 0 0 0 12.06 0C5.43 0 .05 5.37.05 12c0 2.12.55 4.2 1.6 6.03L0 24l6.2-1.62A11.96 11.96 0 0 0 12.05 24h.01c6.62 0 12-5.38 12-12 0-3.2-1.25-6.2-3.54-8.52Zm-8.46 18.5h-.01a9.95 9.95 0 0 1-5.08-1.39l-.36-.21-3.68.96.98-3.59-.23-.37a9.95 9.95 0 0 1-1.53-5.34c0-5.5 4.47-9.98 9.98-9.98 2.66 0 5.16 1.03 7.04 2.92a9.88 9.88 0 0 1 2.92 7.05c0 5.5-4.48 9.98-9.98 9.98Zm5.48-7.48c-.3-.15-1.78-.88-2.06-.98-.28-.1-.48-.15-.69.15-.2.3-.79.98-.97 1.18-.18.2-.35.23-.65.08-.3-.15-1.27-.47-2.42-1.5-.9-.8-1.5-1.8-1.68-2.1-.18-.3-.02-.46.13-.61.13-.13.3-.35.45-.53.15-.18.2-.3.3-.5.1-.2.05-.38-.03-.53-.08-.15-.69-1.66-.94-2.28-.25-.6-.5-.52-.69-.53h-.59c-.2 0-.53.08-.8.38-.28.3-1.06 1.04-1.06 2.53 0 1.49 1.08 2.93 1.23 3.13.15.2 2.13 3.25 5.15 4.56.72.31 1.29.5 1.73.63.73.23 1.39.2 1.91.12.58-.09 1.78-.73 2.03-1.44.25-.71.25-1.32.18-1.44-.08-.12-.28-.2-.58-.35Z" />
      </svg>
      <span class="pointer-events-none absolute right-[calc(100%+0.75rem)] top-1/2 hidden -translate-y-1/2 whitespace-nowrap rounded-full bg-primary px-3 py-1.5 text-xs font-semibold text-primary-foreground shadow-sm sm:block sm:opacity-0 sm:transition sm:duration-200 sm:group-hover:opacity-100 sm:group-focus-visible:opacity-100">
        Escribir por WhatsApp
      </span>
    </a>
    <script>
      import "../main.ts";
    </script>
  </body>
</html>
