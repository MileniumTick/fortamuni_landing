---
import Layout from "../layouts/Layout.astro";

const title = 'Fortamuni | Gestión vial municipal con respaldo técnico';
const description = 'Fortamuni asesora municipalidades en Costa Rica con planes viales quinquenales, inventarios de red vial cantonal, valoración de activos bajo NICSP y soporte técnico para cumplimiento ante CGR, MOPT, Ley 8114 y Ley 9329.';
const canonical = 'https://fortamuni.cr/';
const ogImage = 'https://fortamuni.cr/og-image.jpg';
---

<Layout title={title} description={description} canonical={canonical} ogImage={ogImage}>
  <Fragment slot="head">
    <script type="application/ld+json">
          {
            "@context": "https://schema.org",
            "@type": "ProfessionalService",
            "name": "Fortamuni",
            "url": "https://fortamuni.cr/",
            "logo": "https://fortamuni.cr/favicon.svg",
            "image": "https://fortamuni.cr/og-image.jpg",
            "description": "Firma consultora especializada en gestión vial municipal, planes viales quinquenales, inventarios de la red vial cantonal, valoración de activos bajo NICSP y diagnósticos participativos para gobiernos locales en Costa Rica.",
            "areaServed": {
              "@type": "Country",
              "name": "Costa Rica"
            },
            "founder": {
              "@type": "Person",
              "name": "Ing. Ind. Saskya Carolina Montealegre Cascante",
              "jobTitle": "Consultora Especialista en Gestión Vial y Proyectos Municipales"
            },
            "email": "info@fortamuni.com",
            "knowsAbout": [
              "Gestión vial municipal",
              "Red vial cantonal",
              "Planes Viales Quinquenales de Conservación y Desarrollo",
              "Inventarios viales cantonales",
              "Valoración de activos viales",
              "NICSP",
              "Contraloría General de la República",
              "MOPT",
              "Ley 8114",
              "Ley 9329",
              "UTGV"
            ],
            "contactPoint": {
              "@type": "ContactPoint",
              "contactType": "customer support",
              "areaServed": "CR",
              "email": "info@fortamuni.com",
              "availableLanguage": ["es-CR", "es"]
            },
            "serviceType": [
              "Planes Viales Quinquenales de Conservación y Desarrollo",
              "Inventarios de la Red Vial Cantonal",
              "Valoración de Activos Viales bajo NICSP",
              "Diagnósticos Participativos y Sociales"
            ]
          }
        </script>
    <script type="application/ld+json">
          {
            "@context": "https://schema.org",
            "@type": "FAQPage",
            "mainEntity": [
              {
                "@type": "Question",
                "name": "¿Qué tipo de municipalidades pueden trabajar con Fortamuni?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Fortamuni trabaja con gobiernos locales de Costa Rica que requieren soporte técnico para planificación vial, inventarios de red vial cantonal, valoración de activos bajo NICSP y procesos de priorización vinculados a la UTGV, alcaldías, concejos, proveeduría y hacienda municipal."
                }
              },
              {
                "@type": "Question",
                "name": "¿Fortamuni solo elabora documentos o también ayuda a estructurar la toma de decisiones?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Fortamuni no se limita a producir documentos. El enfoque consiste en transformar datos de campo, criterios normativos y análisis técnico en insumos defendibles ante la CGR, comprensibles para los concejos municipales y útiles para la continuidad operativa del cantón."
                }
              },
              {
                "@type": "Question",
                "name": "¿Cómo ayuda Fortamuni con el cumplimiento normativo?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Fortamuni orienta proyectos y entregables hacia el cumplimiento técnico requerido por la Contraloría General de la República, el MOPT, las Normas Internacionales de Contabilidad para el Sector Público y la correcta inversión de fondos vinculados a la Ley 8114 y la Ley 9329."
                }
              },
              {
                "@type": "Question",
                "name": "¿Qué ocurre después de agendar el diagnóstico?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Después del envío, Fortamuni revisa el contexto del cantón y coordina una conversación diagnóstica inicial. A partir de esa revisión se define si procede una revisión documental, un alcance técnico específico o una ruta de trabajo recomendada para la municipalidad."
                }
              }
            ]
          }
        </script>
  </Fragment>

  <section
          id="hero"
          class="relative overflow-hidden bg-primary px-4 pb-20 pt-32 sm:px-6 lg:px-8 lg:pb-28 lg:pt-40"
          aria-label="Presentación"
          data-section
        >
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_rgba(214,158,46,0.25),_transparent_35%),radial-gradient(circle_at_bottom_left,_rgba(255,255,255,0.08),_transparent_30%)]"></div>
          <div class="relative mx-auto grid max-w-7xl gap-12 lg:grid-cols-[1.2fr_0.8fr] lg:items-center">
            <div>
              <div class="animate-on-scroll inline-flex items-center gap-2 rounded-full border border-accent/30 bg-accent/10 px-4 py-2 text-sm font-semibold text-accent">
                <span class="h-2 w-2 rounded-full bg-accent"></span>
                Diagnóstico técnico inicial para gobiernos locales
              </div>
              <h1 class="animate-on-scroll delay-100 mt-6 max-w-4xl text-4xl font-extrabold leading-tight text-primary-foreground sm:text-5xl lg:text-6xl">
                Agende un diagnóstico técnico inicial para ordenar la gestión vial antes de tomar decisiones críticas.
              </h1>
              <p class="animate-on-scroll delay-200 mt-6 max-w-3xl text-lg leading-8 text-primary-foreground/78 sm:text-xl">
                Revisamos el contexto del cantón, la presión institucional y el problema prioritario para definir con criterio técnico cuál debe ser el siguiente paso: plan vial, inventario, valoración NICSP o priorización de inversión.
              </p>
  
              <div class="animate-on-scroll delay-300 mt-8 flex flex-col gap-4 sm:flex-row">
                <a
                  href="#contacto"
                  class="inline-flex items-center justify-center rounded-full bg-accent px-6 py-4 text-base font-bold text-accent-foreground transition hover:bg-gold-light"
                >
                  Agendar diagnóstico
                </a>
                <a
                  href="#proceso"
                  class="inline-flex items-center justify-center rounded-full border border-white/20 px-6 py-4 text-base font-semibold text-primary-foreground transition hover:border-accent hover:text-accent"
                >
                  Ver cómo trabajamos
                </a>
              </div>
  
              <dl class="animate-on-scroll delay-400 mt-10 grid gap-4 sm:grid-cols-3">
                <div class="rounded-2xl border border-white/10 bg-white/5 p-5">
                  <dt class="text-sm font-medium text-primary-foreground/70">Punto de partida</dt>
                  <dd class="mt-2 text-base font-bold text-primary-foreground">Diagnóstico técnico inicial</dd>
                </div>
                <div class="rounded-2xl border border-white/10 bg-white/5 p-5">
                  <dt class="text-sm font-medium text-primary-foreground/70">Enfoque</dt>
                  <dd class="mt-2 text-base font-bold text-primary-foreground">Diagnóstico + ruta recomendada</dd>
                </div>
                <div class="rounded-2xl border border-white/10 bg-white/5 p-5">
                  <dt class="text-sm font-medium text-primary-foreground/70">Dirigido a</dt>
                  <dd class="mt-2 text-base font-bold text-primary-foreground">UTGV, alcaldías, concejos y hacienda</dd>
                </div>
              </dl>
  
              <div class="animate-on-scroll delay-400 mt-8 flex flex-col gap-3 text-sm text-primary-foreground/72 sm:flex-row sm:flex-wrap sm:items-center">
                <span class="rounded-full border border-white/15 px-4 py-2">SICOP activo</span>
                <span class="rounded-full border border-white/15 px-4 py-2">Enfoque UTGV</span>
                <span class="rounded-full border border-white/15 px-4 py-2">Cumplimiento CGR / MOPT</span>
                <span class="rounded-full border border-white/15 px-4 py-2">NICSP + Ley 8114 / 9329</span>
              </div>
            </div>
  
            <div class="animate-on-scroll delay-300">
              <div class="rounded-[2rem] border border-white/10 bg-white/10 p-6 shadow-2xl shadow-black/20 backdrop-blur">
                <div class="rounded-[1.5rem] bg-surface p-8 text-foreground">
                  <div class="flex items-start justify-between gap-4">
                    <div>
                      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-accent">Oferta inicial</p>
                      <h2 class="mt-3 text-2xl font-extrabold text-primary">Diagnóstico técnico inicial</h2>
                    </div>
                    <span class="rounded-full bg-primary px-3 py-1 text-xs font-bold text-primary-foreground">Costa Rica</span>
                  </div>
  
                  <ul class="mt-6 space-y-4 text-sm leading-7 text-muted-foreground sm:text-base">
                    <li class="flex gap-3">
                      <span class="mt-1 h-2.5 w-2.5 rounded-full bg-accent"></span>
                       Revisión inicial del contexto vial, documental e institucional del cantón.
                    </li>
                    <li class="flex gap-3">
                      <span class="mt-1 h-2.5 w-2.5 rounded-full bg-accent"></span>
                       Identificación del cuello de botella prioritario para no arrancar por intuición.
                    </li>
                    <li class="flex gap-3">
                      <span class="mt-1 h-2.5 w-2.5 rounded-full bg-accent"></span>
                       Definición del siguiente paso recomendado con criterio técnico y lectura municipal real.
                    </li>
                  </ul>
  
                  <div class="mt-8 grid gap-4 sm:grid-cols-2">
                    <div class="rounded-2xl bg-muted p-4">
                      <p class="text-xs font-semibold uppercase tracking-[0.16em] text-muted-foreground">Aplica para</p>
                      <p class="mt-2 text-lg font-bold text-primary">PVQCD, inventarios, NICSP y priorización vial</p>
                    </div>
                    <div class="rounded-2xl bg-muted p-4">
                      <p class="text-xs font-semibold uppercase tracking-[0.16em] text-muted-foreground">Resultado esperado</p>
                      <p class="mt-2 text-lg font-bold text-primary">Ruta clara para avanzar sin improvisar</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>
  
        <section class="bg-surface px-4 py-16 sm:px-6 lg:px-8 lg:py-20" aria-label="Credenciales institucionales">
          <div class="mx-auto max-w-7xl">
            <div class="animate-on-scroll max-w-3xl">
              <p class="text-sm font-bold uppercase tracking-[0.2em] text-accent">Confianza y respaldo</p>
              <h2 class="mt-4 text-3xl font-extrabold text-primary sm:text-4xl">Respaldo institucional para reducir riesgo y sostener decisiones.</h2>
              <p class="mt-6 text-lg leading-8 text-muted-foreground">
                Aquí no basta sonar técnico. Hay que demostrar criterio normativo, conocimiento del cantón y capacidad para sostener auditoría, discusión política y ejecución presupuestaria.
              </p>
            </div>
  
            <div class="mt-12 grid gap-6 md:grid-cols-2 xl:grid-cols-4">
              <article class="animate-on-scroll rounded-[1.75rem] border border-border bg-muted p-6">
                <p class="text-sm font-bold uppercase tracking-[0.16em] text-accent">SICOP</p>
                <h3 class="mt-3 text-xl font-extrabold text-primary">Operación en entorno de contratación pública</h3>
                <p class="mt-4 text-base leading-7 text-muted-foreground">La dirección técnica cuenta con registro activo y experiencia como proveedora adjudicataria dentro del ecosistema estatal costarricense.</p>
              </article>
  
              <article class="animate-on-scroll delay-100 rounded-[1.75rem] border border-border bg-muted p-6">
                <p class="text-sm font-bold uppercase tracking-[0.16em] text-accent">UTGV</p>
                <h3 class="mt-3 text-xl font-extrabold text-primary">Lectura real del trabajo municipal</h3>
                <p class="mt-4 text-base leading-7 text-muted-foreground">La experiencia se alinea con las dinámicas técnicas de las Unidades Técnicas de Gestión Vial y su relación con alcaldías, concejos y áreas de soporte.</p>
              </article>
  
              <article class="animate-on-scroll delay-200 rounded-[1.75rem] border border-border bg-muted p-6">
                <p class="text-sm font-bold uppercase tracking-[0.16em] text-accent">CGR / MOPT</p>
                <h3 class="mt-3 text-xl font-extrabold text-primary">Soporte para cumplimiento y trazabilidad</h3>
                <p class="mt-4 text-base leading-7 text-muted-foreground">Los entregables se construyen considerando lineamientos, validaciones y exigencias que afectan la inversión vial y su defensa técnica.</p>
              </article>
  
              <article class="animate-on-scroll delay-300 rounded-[1.75rem] border border-border bg-muted p-6">
                <p class="text-sm font-bold uppercase tracking-[0.16em] text-accent">NICSP + Leyes</p>
                <h3 class="mt-3 text-xl font-extrabold text-primary">Visión integral de activo, presupuesto y continuidad</h3>
                <p class="mt-4 text-base leading-7 text-muted-foreground">Fortamuni integra valoración de activos, inversión priorizada y continuidad operativa vinculada a la Ley 8114 y la Ley 9329.</p>
              </article>
            </div>
          </div>
        </section>
  
        <section
          id="nosotros"
          class="px-4 py-16 sm:px-6 lg:px-8 lg:py-24"
          aria-label="Sobre nosotros"
          data-section
        >
          <div class="mx-auto max-w-7xl">
            <div class="animate-on-scroll max-w-3xl">
              <p class="text-sm font-bold uppercase tracking-[0.2em] text-accent">Sobre Fortamuni</p>
              <h2 class="mt-4 text-3xl font-extrabold text-primary sm:text-4xl">
                Una firma orientada a convertir planificación vial en decisiones sostenibles para el cantón.
              </h2>
              <p class="mt-6 text-lg leading-8 text-muted-foreground">
                Fortamuni nace para dotar a los gobiernos locales de herramientas técnicas, legales y de planificación vinculantes para el
                desarrollo eficiente de la infraestructura pública. El foco no es la consultoría genérica: es la gestión vial municipal con
                profundidad técnica y criterio institucional.
              </p>
            </div>
  
            <div class="mt-12 grid gap-8 lg:grid-cols-[0.95fr_1.05fr]">
              <article class="animate-on-scroll rounded-[2rem] border border-border bg-surface p-8 shadow-sm">
                <div class="flex items-center gap-5">
                  <div class="flex h-20 w-20 items-center justify-center rounded-3xl bg-primary text-3xl font-extrabold text-primary-foreground">
                    SM
                  </div>
                  <div>
                    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-accent">Dirección técnica</p>
                    <h3 class="mt-2 text-2xl font-extrabold text-primary">Ing. Ind. Saskya Carolina Montealegre Cascante</h3>
                  </div>
                </div>
  
                <div class="mt-8 space-y-5 text-base leading-8 text-muted-foreground">
                  <p>
                    Proveedora activa y adjudicataria en SICOP, con experiencia en asesoría directa a Unidades Técnicas de Gestión Vial y
                    proyectos municipales que demandan rigor documental, lectura normativa y visión de ejecución.
                  </p>
                  <p>
                    Su enfoque combina ingeniería industrial, optimización de recursos públicos y cumplimiento estricto de lineamientos de la
                    Contraloría General de la República y del MOPT.
                  </p>
                </div>
  
                <dl class="mt-8 grid gap-4 sm:grid-cols-2">
                  <div class="rounded-2xl bg-muted p-5">
                    <dt class="text-sm font-medium text-muted-foreground">Trayectoria aplicada</dt>
                    <dd class="mt-2 font-bold text-primary">Gestión vial y proyectos municipales</dd>
                  </div>
                  <div class="rounded-2xl bg-muted p-5">
                    <dt class="text-sm font-medium text-muted-foreground">Registro público</dt>
                    <dd class="mt-2 font-bold text-primary">Operadora activa en SICOP</dd>
                  </div>
                </dl>
              </article>
  
              <div class="space-y-6">
                <article class="animate-on-scroll delay-100 rounded-[2rem] border border-border bg-muted p-8">
                  <h3 class="text-2xl font-extrabold text-primary">Lo que resolvemos para una municipalidad</h3>
                  <ul class="mt-6 space-y-4 text-base leading-8 text-muted-foreground">
                    <li class="flex gap-3"><span class="mt-2 h-2.5 w-2.5 rounded-full bg-accent"></span>Definimos rutas técnicas de inversión a 5 años para evitar improvisación presupuestaria.</li>
                    <li class="flex gap-3"><span class="mt-2 h-2.5 w-2.5 rounded-full bg-accent"></span>Actualizamos el estado real de la red vial con levantamiento de datos y criterios de priorización.</li>
                    <li class="flex gap-3"><span class="mt-2 h-2.5 w-2.5 rounded-full bg-accent"></span>Respaldamos estados financieros y auditorías con valoración de activos alineada a NICSP.</li>
                    <li class="flex gap-3"><span class="mt-2 h-2.5 w-2.5 rounded-full bg-accent"></span>Integramos necesidades comunitarias sin perder estructura técnica ni trazabilidad.</li>
                  </ul>
                </article>
  
                <article class="animate-on-scroll delay-200 rounded-[2rem] border border-accent/30 bg-primary p-8 text-primary-foreground">
                  <p class="text-sm font-semibold uppercase tracking-[0.18em] text-accent">Resultado esperado</p>
                  <blockquote class="mt-4 text-2xl font-bold leading-tight sm:text-3xl">
                    Documentos técnicamente sólidos, políticamente defendibles y operativamente ejecutables.
                  </blockquote>
                  <p class="mt-5 text-base leading-8 text-primary-foreground/78">
                    Ese es el punto que muchos improvisan. Fortamuni no vende papeles: entrega estructura de decisión.
                  </p>
                </article>
              </div>
            </div>
          </div>
        </section>
  
        <section id="proceso" class="bg-primary px-4 py-16 sm:px-6 lg:px-8 lg:py-24" aria-label="Proceso de trabajo">
          <div class="mx-auto max-w-7xl">
            <div class="animate-on-scroll max-w-3xl text-primary-foreground">
              <p class="text-sm font-bold uppercase tracking-[0.2em] text-accent">Metodología de trabajo</p>
              <h2 class="mt-4 text-3xl font-extrabold sm:text-4xl">Un proceso para ordenar información, priorizar inversión y sostener decisiones.</h2>
              <p class="mt-6 text-lg leading-8 text-primary-foreground/78">
                La municipalidad no necesita más documentos sueltos. Necesita una secuencia técnica que parta de la realidad del cantón y termine en insumos ejecutables y defendibles.
              </p>
            </div>
  
            <div class="mt-12 grid gap-6 lg:grid-cols-5">
              <article class="animate-on-scroll rounded-[1.75rem] border border-white/10 bg-white/5 p-6 text-primary-foreground">
                <p class="text-sm font-bold text-accent">01</p>
                <h3 class="mt-3 text-xl font-extrabold">Diagnóstico inicial</h3>
                <p class="mt-4 text-sm leading-7 text-primary-foreground/76">Revisión del contexto del cantón, necesidad institucional, estado documental y objetivo técnico prioritario.</p>
              </article>
              <article class="animate-on-scroll delay-100 rounded-[1.75rem] border border-white/10 bg-white/5 p-6 text-primary-foreground">
                <p class="text-sm font-bold text-accent">02</p>
                <h3 class="mt-3 text-xl font-extrabold">Levantamiento y análisis</h3>
                <p class="mt-4 text-sm leading-7 text-primary-foreground/76">Recopilación de datos físicos, revisión normativa y estructuración de variables para priorización y valoración.</p>
              </article>
              <article class="animate-on-scroll delay-200 rounded-[1.75rem] border border-white/10 bg-white/5 p-6 text-primary-foreground">
                <p class="text-sm font-bold text-accent">03</p>
                <h3 class="mt-3 text-xl font-extrabold">Modelo de priorización</h3>
                <p class="mt-4 text-sm leading-7 text-primary-foreground/76">Definición de criterios técnicos y matrices que ayuden a justificar decisiones de inversión ante diferentes actores.</p>
              </article>
              <article class="animate-on-scroll delay-300 rounded-[1.75rem] border border-white/10 bg-white/5 p-6 text-primary-foreground">
                <p class="text-sm font-bold text-accent">04</p>
                <h3 class="mt-3 text-xl font-extrabold">Entregable defendible</h3>
                <p class="mt-4 text-sm leading-7 text-primary-foreground/76">Producción de documentos técnicamente sólidos, comprensibles para decisión política y consistentes con el entorno regulatorio.</p>
              </article>
              <article class="animate-on-scroll delay-400 rounded-[1.75rem] border border-white/10 bg-white/5 p-6 text-primary-foreground">
                <p class="text-sm font-bold text-accent">05</p>
                <h3 class="mt-3 text-xl font-extrabold">Seguimiento y continuidad</h3>
                <p class="mt-4 text-sm leading-7 text-primary-foreground/76">Acompañamiento orientado a que la inversión no dependa solo del ciclo político, sino de una estructura técnica previa.</p>
              </article>
            </div>
          </div>
        </section>
  
        <section class="bg-surface px-4 py-16 sm:px-6 lg:px-8 lg:py-24" aria-label="Riesgos que ayudamos a evitar">
          <div class="mx-auto max-w-7xl">
            <div class="animate-on-scroll max-w-3xl">
              <p class="text-sm font-bold uppercase tracking-[0.2em] text-accent">Riesgos que ayudamos a evitar</p>
              <h2 class="mt-4 text-3xl font-extrabold text-primary sm:text-4xl">Cuando la gestión vial se improvisa, el problema deja de ser solo técnico.</h2>
              <p class="mt-6 text-lg leading-8 text-muted-foreground">
                Una mala priorización, un inventario débil o una valoración incompleta atrasan proyectos y complican auditoría, ejecución y continuidad del cantón.
              </p>
            </div>
  
            <div class="mt-12 grid gap-6 md:grid-cols-2 xl:grid-cols-4">
              <article class="animate-on-scroll rounded-[1.75rem] border border-border bg-muted p-6">
                <h3 class="text-xl font-extrabold text-primary">Observaciones por falta de trazabilidad</h3>
                <p class="mt-4 text-base leading-7 text-muted-foreground">Cuando la municipalidad no logra demostrar por qué priorizó una intervención, la inversión queda expuesta a cuestionamientos técnicos y de control.</p>
              </article>
              <article class="animate-on-scroll delay-100 rounded-[1.75rem] border border-border bg-muted p-6">
                <h3 class="text-xl font-extrabold text-primary">Discontinuidad por cambios políticos</h3>
                <p class="mt-4 text-base leading-7 text-muted-foreground">Sin una hoja de ruta clara, cada cambio de administración reinicia la conversación y erosiona el avance acumulado del cantón.</p>
              </article>
              <article class="animate-on-scroll delay-200 rounded-[1.75rem] border border-border bg-muted p-6">
                <h3 class="text-xl font-extrabold text-primary">Activos mal registrados o subvalorados</h3>
                <p class="mt-4 text-base leading-7 text-muted-foreground">La valoración deficiente bajo NICSP afecta estados financieros, soporte documental y lectura real del patrimonio público vial.</p>
              </article>
              <article class="animate-on-scroll delay-300 rounded-[1.75rem] border border-border bg-muted p-6">
                <h3 class="text-xl font-extrabold text-primary">Presupuesto sin criterio territorial</h3>
                <p class="mt-4 text-base leading-7 text-muted-foreground">Cuando no se incorpora realidad productiva, turística, comunitaria y física de la red vial, la inversión pierde impacto y legitimidad.</p>
              </article>
            </div>
          </div>
        </section>
  
        <section class="bg-muted px-4 py-16 sm:px-6 lg:px-8 lg:py-24" aria-label="Por qué Fortamuni">
          <div class="mx-auto max-w-7xl">
            <div class="animate-on-scroll max-w-3xl">
              <p class="text-sm font-bold uppercase tracking-[0.2em] text-accent">Por qué Fortamuni</p>
