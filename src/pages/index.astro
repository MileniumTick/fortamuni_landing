---
import Layout from "../layouts/Layout.astro";

const title = 'Gestión vial municipal en Costa Rica | Fortamuni';
const description = 'Asesoría en gestión vial municipal para gobiernos locales: priorización de inversión, inventario de red vial cantonal y cumplimiento técnico ante CGR, MOPT, Ley 8114 y Ley 9329.';
const canonical = 'https://fortamuni.com/';
const ogImage = 'https://fortamuni.com/og-image.jpg';
const logoImage = 'https://fortamuni.com/fortamuni-logo.svg';
const markImage = 'https://fortamuni.com/fortamuni-mark.svg';
---

<Layout title={title} description={description} canonical={canonical} ogImage={ogImage}>
  <Fragment slot="head">
    <script type="application/ld+json">
          {
            "@context": "https://schema.org",
            "@type": "ProfessionalService",
            "name": "Fortamuni",
            "url": "https://fortamuni.com/",
            "logo": logoImage,
            "image": "https://fortamuni.com/og-image.jpg",
            "description": "Firma consultora especializada en gestión vial municipal, planes viales quinquenales, inventarios de la red vial cantonal, valoración de activos bajo NICSP y diagnósticos participativos para gobiernos locales en Costa Rica.",
            "areaServed": {
              "@type": "Country",
              "name": "Costa Rica"
            },
            "founder": {
              "@type": "Person",
              "name": "Ing. Ind. Saskya Carolina Montealegre Cascante",
              "jobTitle": "Consultora Especialista en Gestión Vial y Proyectos Municipales"
            },
            "email": "fortamunisaskya@gmail.com",
            "knowsAbout": [
              "Gestión vial municipal",
              "Red vial cantonal",
              "Planes Viales Quinquenales de Conservación y Desarrollo",
              "Inventarios viales cantonales",
              "Valoración de activos viales",
              "NICSP",
              "Contraloría General de la República",
              "MOPT",
              "Ley 8114",
              "Ley 9329",
              "UTGV"
            ],
            "contactPoint": {
              "@type": "ContactPoint",
              "contactType": "customer support",
              "areaServed": "CR",
              "email": "fortamunisaskya@gmail.com",
              "availableLanguage": ["es-CR", "es"]
            },
            "serviceType": [
              "Planes Viales Quinquenales de Conservación y Desarrollo",
              "Inventarios de la Red Vial Cantonal",
              "Valoración de Activos Viales bajo NICSP",
              "Diagnósticos Participativos y Sociales"
            ]
          }
        </script>
    <script type="application/ld+json">
          {
            "@context": "https://schema.org",
            "@type": "FAQPage",
            "mainEntity": [
              {
                "@type": "Question",
                "name": "¿Qué tipo de municipalidades pueden trabajar con Fortamuni?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Fortamuni trabaja con gobiernos locales de Costa Rica que necesitan ordenar su gestión vial, sustentar decisiones de inversión o fortalecer su soporte técnico y documental. El acompañamiento se adapta a la realidad de la UTGV, alcaldías, concejos, proveeduría y hacienda municipal."
                }
              },
              {
                "@type": "Question",
                "name": "¿Fortamuni solo elabora documentos o también ayuda a estructurar la toma de decisiones?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Fortamuni no se limita a producir documentos. El enfoque consiste en convertir datos de campo, criterios normativos y análisis técnico en insumos defendibles ante la CGR, comprensibles para el concejo municipal y útiles para la continuidad operativa del cantón."
                }
              },
              {
                "@type": "Question",
                "name": "¿Cómo ayuda Fortamuni con el cumplimiento normativo?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Fortamuni orienta proyectos y entregables hacia el cumplimiento técnico requerido por la Contraloría General de la República, el MOPT, las Normas Internacionales de Contabilidad para el Sector Público y la correcta inversión de fondos vinculados a la Ley 8114 y la Ley 9329."
                }
              },
              {
                "@type": "Question",
                "name": "¿Qué ocurre después de agendar el diagnóstico?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Después del envío, Fortamuni revisa el contexto del cantón y coordina una conversación diagnóstica inicial. A partir de esa revisión se define si procede una revisión documental, un alcance técnico específico o una ruta de trabajo recomendada para la municipalidad."
                }
              }
            ]
          }
        </script>
  </Fragment>

  <section
          id="hero"
          class="brand-hero-glow relative overflow-hidden px-4 pb-20 pt-32 sm:px-6 lg:px-8 lg:pb-28 lg:pt-40"
          aria-label="Presentación"
          data-section
        >
          <div class="brand-grid-overlay absolute inset-0 opacity-40"></div>
          <div class="relative mx-auto grid max-w-7xl gap-10 lg:grid-cols-[1.2fr_0.8fr] lg:items-center lg:gap-12">
            <div>
              <div class="animate-on-scroll inline-flex items-center gap-2 rounded-full border border-white/12 bg-white/8 px-4 py-2 text-sm font-semibold text-primary-foreground shadow-lg shadow-black/10 backdrop-blur-sm">
                <span class="brand-icon-badge brand-icon-badge--accent h-6 w-6 rounded-full border-0 bg-white/12 text-inherit">
                  <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-3.5 w-3.5 fill-none stroke-current stroke-[2.2]">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m5 13 4 4L19 7" />
                  </svg>
                </span>
                Diagnóstico técnico inicial para gobiernos locales
              </div>
              <h1 class="animate-on-scroll delay-100 mt-5 max-w-4xl text-4xl font-extrabold leading-tight text-primary-foreground sm:mt-6 sm:text-5xl lg:text-6xl">
                Gestión vial municipal para decidir inversión con criterio técnico y respaldo institucional.
              </h1>
              <p class="animate-on-scroll delay-200 mt-5 max-w-3xl text-base leading-8 text-primary-foreground/78 sm:mt-6 sm:text-lg sm:leading-8 lg:text-xl">
                Acompañamos a municipalidades de Costa Rica a ordenar su red vial cantonal, priorizar proyectos y cumplir Ley 8114 y Ley 9329 con soporte defendible ante auditoría y concejo municipal.
              </p>

              <div class="animate-on-scroll delay-300 mt-7 flex flex-col gap-3 sm:mt-8 sm:flex-row sm:gap-4">
                <a
                  href="#contacto"
                  class="inline-flex w-full items-center justify-center rounded-full bg-accent px-6 py-4 text-base font-bold text-accent-foreground transition hover:bg-[var(--color-accent-hover)] sm:w-auto"
                >
                  Agendar diagnóstico
                </a>
                <a
                  href="#proceso"
                  class="inline-flex w-full items-center justify-center rounded-full border border-white/20 px-6 py-4 text-base font-semibold text-primary-foreground transition hover:border-white hover:bg-white/5 sm:w-auto"
                >
                  Ver cómo trabajamos
                </a>
              </div>

              <dl class="animate-on-scroll delay-400 mt-8 grid gap-3 sm:mt-10 sm:grid-cols-3 sm:gap-4">
                <div class="brand-outline-panel rounded-2xl border border-white/10 bg-white/6 p-4 backdrop-blur-sm sm:p-5">
                  <dt class="text-sm font-medium text-primary-foreground/70">Propuesta de valor</dt>
                  <dd class="mt-2 text-base font-bold text-primary-foreground">Gestión vial con soporte técnico e institucional</dd>
                </div>
                <div class="brand-outline-panel rounded-2xl border border-white/10 bg-white/6 p-4 backdrop-blur-sm sm:p-5">
                  <dt class="text-sm font-medium text-primary-foreground/70">Enfoque</dt>
                  <dd class="mt-2 text-base font-bold text-primary-foreground">Diagnóstico, priorización y trazabilidad</dd>
                </div>
                <div class="brand-outline-panel rounded-2xl border border-white/10 bg-white/6 p-4 backdrop-blur-sm sm:p-5">
                  <dt class="text-sm font-medium text-primary-foreground/70">Dirigido a</dt>
                  <dd class="mt-2 text-base font-bold text-primary-foreground">UTGV, alcaldías, concejos, hacienda y proveeduría</dd>
                </div>
              </dl>

              <div class="animate-on-scroll delay-400 mt-8 flex flex-col gap-2.5 text-sm text-primary-foreground/72 sm:flex-row sm:flex-wrap sm:items-center sm:gap-3">
                <span class="brand-chip rounded-full px-4 py-2">SICOP activo</span>
                <span class="brand-chip rounded-full px-4 py-2">Enfoque UTGV</span>
                <span class="brand-chip rounded-full px-4 py-2">Cumplimiento CGR / MOPT</span>
                <span class="brand-chip rounded-full px-4 py-2">NICSP + Ley 8114 / 9329</span>
              </div>
            </div>

            <div class="animate-on-scroll delay-300">
              <div class="brand-glass-card rounded-[2rem] p-4 sm:p-6">
                <div class="rounded-[1.5rem] bg-surface p-6 text-foreground sm:p-8">
                  <div class="flex items-start justify-between gap-4">
                    <div>
                      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-accent">Oferta inicial</p>
                      <h2 class="mt-3 text-2xl font-extrabold text-primary">Diagnóstico técnico inicial</h2>
                    </div>
                    <span class="brand-chip rounded-full px-3 py-1 text-xs font-bold">Costa Rica</span>
                  </div>

                  <ul class="brand-bullet-list mt-6 text-sm leading-7 text-muted-foreground sm:text-base">
                    <li>
                      <span class="brand-icon-badge brand-icon-badge--accent brand-bullet-icon h-9 w-9 rounded-xl">
                        <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-4.5 w-4.5 fill-none stroke-current stroke-[2]">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2" />
                          <circle cx="12" cy="12" r="8" />
                        </svg>
                      </span>
                      <span>Revisión inicial del contexto vial, documental e institucional del cantón.</span>
                    </li>
                    <li>
                      <span class="brand-icon-badge brand-icon-badge--success brand-bullet-icon h-9 w-9 rounded-xl">
                        <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-4.5 w-4.5 fill-none stroke-current stroke-[2]">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M3 12h6l3-7 4 14 3-7h2" />
                        </svg>
                      </span>
                      <span>Identificación del cuello de botella prioritario para no arrancar por intuición.</span>
                    </li>
                    <li>
                      <span class="brand-icon-badge brand-bullet-icon h-9 w-9 rounded-xl">
                        <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-4.5 w-4.5 fill-none stroke-current stroke-[2]">
                          <path stroke-linecap="round" stroke-linejoin="round" d="m5 12 4 4L19 6" />
                        </svg>
                      </span>
                      <span>Definición del siguiente paso recomendado con criterio técnico y lectura municipal real.</span>
                    </li>
                  </ul>

                  <div class="mt-7 grid gap-3 sm:mt-8 sm:grid-cols-2 sm:gap-4">
                    <div class="brand-soft-panel rounded-2xl p-4">
                      <p class="text-xs font-semibold uppercase tracking-[0.16em] text-muted-foreground">Aplica para</p>
                      <p class="mt-2 text-lg font-bold text-primary">PVQCD, inventarios, NICSP, auditoría y priorización vial</p>
                    </div>
                    <div class="brand-soft-panel rounded-2xl p-4">
                      <p class="text-xs font-semibold uppercase tracking-[0.16em] text-muted-foreground">Resultado esperado</p>
                      <p class="mt-2 text-lg font-bold text-primary">Ruta clara para avanzar sin improvisar ni exponer la decisión</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>
  
        <section class="bg-surface px-4 py-14 sm:px-6 sm:py-16 lg:px-8 lg:py-20" aria-label="Credenciales institucionales">
          <div class="mx-auto max-w-7xl">
            <div class="animate-on-scroll max-w-3xl">
              <p class="text-sm font-bold uppercase tracking-[0.2em] text-accent">Confianza y respaldo</p>
              <h2 class="mt-4 max-w-2xl text-3xl font-extrabold text-primary sm:text-4xl">Capacidad técnica orientada a cumplimiento, inversión y continuidad institucional.</h2>
              <p class="mt-5 max-w-2xl text-base leading-8 text-muted-foreground sm:mt-6 sm:text-lg">
                La gestión vial municipal exige metodología, lectura territorial y trazabilidad documental. También exige entregables que sirvan para auditoría, aprobación política y ejecución presupuestaria.
              </p>
            </div>

            <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-4 xl:gap-6">
              <article class="animate-on-scroll rounded-[1.75rem] border border-border bg-muted p-5 sm:p-6">
                <p class="text-sm font-bold uppercase tracking-[0.16em] text-accent">Cumplimiento</p>
                <h3 class="mt-3 text-lg font-extrabold text-primary sm:text-xl">Lectura normativa aplicada al entorno municipal</h3>
                <p class="mt-3 text-base leading-7 text-muted-foreground">Los servicios se estructuran considerando exigencias de CGR, MOPT, Ley 8114, Ley 9329 y registros clave para el trabajo técnico municipal.</p>
              </article>

              <article class="animate-on-scroll delay-100 rounded-[1.75rem] border border-border bg-muted p-5 sm:p-6">
                <p class="text-sm font-bold uppercase tracking-[0.16em] text-accent">Capacidad técnica</p>
                <h3 class="mt-3 text-lg font-extrabold text-primary sm:text-xl">Trabajo alineado con la operación real de la UTGV</h3>
                <p class="mt-3 text-base leading-7 text-muted-foreground">La metodología conversa con la realidad de la UTGV, alcaldía, concejo, hacienda y proveeduría para que el entregable no quede aislado del proceso institucional.</p>
              </article>

              <article class="animate-on-scroll delay-200 rounded-[1.75rem] border border-border bg-muted p-5 sm:p-6">
                <p class="text-sm font-bold uppercase tracking-[0.16em] text-accent">Trazabilidad</p>
                <h3 class="mt-3 text-lg font-extrabold text-primary sm:text-xl">Información ordenada para justificar decisiones</h3>
                <p class="mt-3 text-base leading-7 text-muted-foreground">Se prioriza que los datos, criterios y resultados puedan explicarse, auditarse y sostenerse en espacios de decisión técnica y política.</p>
              </article>

              <article class="animate-on-scroll delay-300 rounded-[1.75rem] border border-border bg-muted p-5 sm:p-6">
                <p class="text-sm font-bold uppercase tracking-[0.16em] text-accent">Sector público</p>
                <h3 class="mt-3 text-lg font-extrabold text-primary sm:text-xl">Enfoque sobre activo público e inversión vial</h3>
                <p class="mt-3 text-base leading-7 text-muted-foreground">Fortamuni integra inventario, priorización y valoración patrimonial para que la infraestructura vial se gestione como activo público y no como listado aislado de obras.</p>
              </article>
            </div>
          </div>
        </section>
  
        <section
          id="nosotros"
          class="px-4 py-16 sm:px-6 lg:px-8 lg:py-24"
          aria-label="Sobre nosotros"
          data-section
        >
          <div class="mx-auto max-w-7xl">
            <div class="animate-on-scroll max-w-3xl">
              <p class="text-sm font-bold uppercase tracking-[0.2em] text-accent">Sobre Fortamuni</p>
              <h2 class="mt-4 text-3xl font-extrabold text-primary sm:text-4xl">
                Gestión vial municipal con criterio técnico, respaldo documental y lectura institucional.
              </h2>
              <p class="mt-6 text-lg leading-8 text-muted-foreground">
                Fortamuni acompaña a gobiernos locales que necesitan ordenar información, justificar prioridades y convertir planeamiento vial en decisiones utilizables dentro de la institución.
              </p>
            </div>
  
            <div class="mt-12 grid gap-8 lg:grid-cols-[0.95fr_1.05fr]">
              <article class="animate-on-scroll brand-outline-panel rounded-[2rem] border border-border bg-surface p-8 shadow-sm">
                <div class="flex items-center gap-5">
                  <div class="brand-soft-panel flex h-20 w-20 items-center justify-center rounded-3xl p-3 shadow-sm">
                    <img src="/fortamuni-mark.svg" alt="" class="h-full w-full" loading="lazy" decoding="async" />
                  </div>
                  <div>
                    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-accent">Dirección técnica</p>
                    <h3 class="mt-2 text-2xl font-extrabold text-primary">Ing. Ind. Saskya Carolina Montealegre Cascante</h3>
                  </div>
                </div>
  
                <div class="mt-8 space-y-5 text-base leading-8 text-muted-foreground">
                  <p>
                    Proveedora activa y adjudicataria en SICOP, con experiencia en asesoría directa a Unidades Técnicas de Gestión Vial y
                    proyectos municipales que exigen rigor documental, lectura normativa y viabilidad operativa.
                  </p>
                  <p>
                    Su enfoque combina ingeniería industrial, optimización de recursos públicos y cumplimiento de lineamientos de la
                    Contraloría General de la República y del MOPT.
                  </p>
                </div>
  
                <dl class="mt-8 grid gap-4 sm:grid-cols-2">
                  <div class="brand-soft-panel rounded-2xl p-5">
                    <dt class="text-sm font-medium text-muted-foreground">Trayectoria aplicada</dt>
                    <dd class="mt-2 font-bold text-primary">Gestión vial y proyectos municipales</dd>
                  </div>
                  <div class="brand-soft-panel rounded-2xl p-5">
                    <dt class="text-sm font-medium text-muted-foreground">Registro público</dt>
                    <dd class="mt-2 font-bold text-primary">Operadora activa en SICOP</dd>
                  </div>
                </dl>
              </article>

              <div class="space-y-6">
                <article class="animate-on-scroll delay-100 rounded-[2rem] border border-border bg-muted p-8">
                  <h3 class="text-2xl font-extrabold text-primary">Dónde Fortamuni aporta valor en la gestión municipal</h3>
                  <ul class="brand-bullet-list mt-6 text-base leading-8 text-muted-foreground">
                    <li><span class="brand-icon-badge brand-bullet-icon h-9 w-9 rounded-xl"><svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-4.5 w-4.5 fill-none stroke-current stroke-[2]"><path stroke-linecap="round" stroke-linejoin="round" d="M4 19h16M5 16l4.5-5 3.5 3 5.5-7" /></svg></span><span>Definimos rutas técnicas de inversión con horizonte quinquenal para reducir improvisación presupuestaria y dar continuidad entre administraciones.</span></li>
                    <li><span class="brand-icon-badge brand-icon-badge--success brand-bullet-icon h-9 w-9 rounded-xl"><svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-4.5 w-4.5 fill-none stroke-current stroke-[2]"><path stroke-linecap="round" stroke-linejoin="round" d="M6 19h12M7 16V8l5-3 5 3v8" /></svg></span><span>Actualizamos la lectura real de la red vial con información útil para UTGV, priorización y programación presupuestaria.</span></li>
                    <li><span class="brand-icon-badge brand-icon-badge--accent brand-bullet-icon h-9 w-9 rounded-xl"><svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-4.5 w-4.5 fill-none stroke-current stroke-[2]"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M7 12h10M9 18h6" /></svg></span><span>Fortalecemos auditoría, estados financieros y trazabilidad institucional con valoración de activos alineada a NICSP.</span></li>
                    <li><span class="brand-icon-badge brand-bullet-icon h-9 w-9 rounded-xl"><svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-4.5 w-4.5 fill-none stroke-current stroke-[2]"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v18M3 12h18" /></svg></span><span>Incorporamos criterio territorial y necesidades comunitarias sin perder estructura técnica ni defendibilidad documental.</span></li>
                  </ul>
                </article>

                <article class="animate-on-scroll delay-200 brand-outline-panel rounded-[2rem] border border-white/10 bg-primary p-8 text-primary-foreground">
                  <p class="text-sm font-semibold uppercase tracking-[0.18em] text-accent">Resultado esperado</p>
                  <blockquote class="mt-4 text-2xl font-bold leading-tight sm:text-3xl">
                    Insumos técnicamente sólidos, institucionalmente claros y operativamente útiles para decidir con respaldo.
                  </blockquote>
                  <p class="mt-5 text-base leading-8 text-primary-foreground/78">
                    Ese es el punto clave. Fortamuni no trabaja para llenar archivos: trabaja para dejar criterio técnico que sirva en campo, en presupuesto y ante control.
                  </p>
                </article>
              </div>
            </div>
          </div>
        </section>
  
        <section id="proceso" class="brand-hero-glow relative overflow-hidden px-4 py-16 sm:px-6 lg:px-8 lg:py-24" aria-label="Proceso de trabajo">
          <div class="brand-grid-overlay absolute inset-0 opacity-30"></div>
          <div class="mx-auto max-w-7xl">
            <div class="animate-on-scroll relative max-w-3xl text-primary-foreground">
              <p class="text-sm font-bold uppercase tracking-[0.2em] text-accent">Metodología de trabajo</p>
              <h2 class="mt-4 text-3xl font-extrabold sm:text-4xl">Una metodología para levantar información, convertirla en criterio y traducirla en inversión defendible.</h2>
              <p class="mt-6 text-lg leading-8 text-primary-foreground/78">
                La municipalidad no necesita más documentos sueltos. Necesita una secuencia técnica que parta de la realidad física e institucional del cantón y termine en insumos utilizables para decisión, ejecución y seguimiento.
              </p>
            </div>
            <div class="relative mt-12 grid gap-6 lg:grid-cols-5">
              <article class="animate-on-scroll brand-outline-panel rounded-[1.75rem] border border-white/10 bg-white/6 p-6 text-primary-foreground backdrop-blur-sm">
                <p class="text-sm font-bold text-accent">01</p>
                <h3 class="mt-3 text-xl font-extrabold">Diagnóstico y alcance</h3>
                <p class="mt-4 text-sm leading-7 text-primary-foreground/76">Se revisa el contexto del cantón, el estado documental, la necesidad institucional y el objetivo técnico que realmente debe atenderse primero.</p>
              </article>
              <article class="animate-on-scroll delay-100 brand-outline-panel rounded-[1.75rem] border border-white/10 bg-white/6 p-6 text-primary-foreground backdrop-blur-sm">
                <p class="text-sm font-bold text-accent">02</p>
                <h3 class="mt-3 text-xl font-extrabold">Levantamiento y depuración</h3>
                <p class="mt-4 text-sm leading-7 text-primary-foreground/76">Se recopilan datos físicos, administrativos y normativos para ordenar la base técnica con la que se va a priorizar, registrar o valorar.</p>
              </article>
              <article class="animate-on-scroll delay-200 brand-outline-panel rounded-[1.75rem] border border-white/10 bg-white/6 p-6 text-primary-foreground backdrop-blur-sm">
                <p class="text-sm font-bold text-accent">03</p>
                <h3 class="mt-3 text-xl font-extrabold">Análisis y priorización</h3>
                <p class="mt-4 text-sm leading-7 text-primary-foreground/76">Se aplican criterios técnicos, territoriales y normativos para construir una priorización entendible y defendible ante distintos actores.</p>
              </article>
              <article class="animate-on-scroll delay-300 brand-outline-panel rounded-[1.75rem] border border-white/10 bg-white/6 p-6 text-primary-foreground backdrop-blur-sm">
                <p class="text-sm font-bold text-accent">04</p>
                <h3 class="mt-3 text-xl font-extrabold">Entregables y socialización</h3>
